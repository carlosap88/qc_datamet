# =============================================================================
# QC_DATAMET
# .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------

__pycache__/
*.py[cod]
*$py.class

# -----------------------------------------------------------------------------
# Compiled Extensions
# -----------------------------------------------------------------------------

*.so
*.pyd
*.dll

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------

.venv/
venv/
env/

# -----------------------------------------------------------------------------
# Conda
# -----------------------------------------------------------------------------

.conda/
conda-meta/

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------

.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------

.vscode/
.idea/

# -----------------------------------------------------------------------------
# Environment Variables
# -----------------------------------------------------------------------------

.env
.env.*

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------

logs/*
!logs/.gitkeep

# -----------------------------------------------------------------------------
# Generated Reports
# -----------------------------------------------------------------------------

reports/**/*
!reports/**/.gitkeep

# -----------------------------------------------------------------------------
# Raw Source Data
# -----------------------------------------------------------------------------

# Los datos originales permanecen únicamente en el entorno local.
data/raw/**/*
!data/raw/**/
!data/raw/**/.gitkeep

# -----------------------------------------------------------------------------
# Temporary and Generated Data
# -----------------------------------------------------------------------------

data/staging/*
!data/staging/.gitkeep

data/processed/*
!data/processed/.gitkeep

data/consolidated/*
!data/consolidated/.gitkeep

data/final/*
!data/final/.gitkeep

data/parquet/cache/*
!data/parquet/cache/.gitkeep

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------

.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# -----------------------------------------------------------------------------
# Coverage
# -----------------------------------------------------------------------------

.coverage
htmlcov/

# -----------------------------------------------------------------------------
# Build
# -----------------------------------------------------------------------------

build/
dist/
*.egg-info/

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------

Thumbs.db
Desktop.ini
.DS_Store

# -----------------------------------------------------------------------------
# Office Temporary Files
# -----------------------------------------------------------------------------

~$*

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------

*.tmp
*.temp

# -----------------------------------------------------------------------------
# Project Generated Files
# -----------------------------------------------------------------------------

qc_datamet_source_dump.txt

# -----------------------------------------------------------------------------
# Backup Files
# -----------------------------------------------------------------------------

*.bak
*.old
*.orig

# -----------------------------------------------------------------------------
# Local Databases
# -----------------------------------------------------------------------------

*.sqlite
*.db
